{
  "manifest_version": 3,
  "name": "ArSonKuPik",
  "short_name": "ArSonKuPik",
  "description": "Lightweight mastering-style browser audio processor with precision EQ, compressor, harmonic color, stereo width, limiter and output routing. Local processing only.",
  "version": "0.3.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ArSonKuPik"
  },
  "permissions": [
    "activeTab",
    "tabCapture",
    "offscreen",
    "storage",
    "contentSettings"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "studio.html"
}
